{
  "name": "fish-tycoon-2",
  "private": true,
  "version": "0.9.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npx vite preview",
    "deploy": "vite build && npx gh-pages -d dist",
    "electron:dev": "concurrently \"npx vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "cross-env ELECTRON=true vite build && electron-builder",
    "electron:build:win": "cross-env ELECTRON=true vite build && electron-builder --win",
    "electron:build:mac": "cross-env ELECTRON=true vite build && electron-builder --mac",
    "electron:build:linux": "cross-env ELECTRON=true vite build && electron-builder --linux"
  },
  "dependencies": {
    "immer": "^11.1.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "gh-pages": "^6.1.1",
    "vite": "^5.0.0",
    "wait-on": "^8.0.0"
  }
}
